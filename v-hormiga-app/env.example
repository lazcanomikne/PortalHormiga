# API Configuration (.NET PortalGovi: suele ser puerto 5005)
VITE_API_URL=http://127.0.0.1:5005/api
# Timeout axios (ms); listado cotizaciones usa al menos 180s si HANA es lento
VITE_API_TIMEOUT_MS=120000
# Solo si no defines VITE_API_URL en dev (fallback localhost)
VITE_API_DEV_PORT=5005

# App Configuration
VITE_APP_NAME=HORMIGA
VITE_APP_VERSION=1.0.0

# Development Configuration
VITE_DEV_MODE=true 